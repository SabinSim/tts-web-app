@page "/translate"
@rendermode InteractiveServer
@inject TranslationService TranslationSvc
@inject OpenAiTtsService TtsService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Translate — TTS Web App</PageTitle>

<div class="tr-card">

    <div class="tr-header">
        <h2>Translator</h2>
        <p>Translate between Korean, English, and German — then listen or send to TTS.</p>
    </div>

    <div class="tr-lang-bar">
        @foreach (var lang in TranslationSvc.Languages)
        {
            <button class="tr-lang-btn @(sourceLang == lang.Code ? "active" : "")"
                    @onclick="() => sourceLang = lang.Code">
                @lang.Label
            </button>
        }
    </div>

    <textarea class="tr-input"
              @bind="inputText"
              @bind:event="oninput"
              rows="5"
              placeholder="Enter text…"></textarea>

    <div class="tr-divider">
        <span class="tr-divider-arrow">↓</span>
    </div>

    <div class="tr-lang-bar">
        @foreach (var lang in TranslationSvc.Languages.Where(l => l.Code != "auto"))
        {
            <button class="tr-lang-btn @(targetLang == lang.Code ? "active" : "")"
                    @onclick="() => { targetLang = lang.Code; translatedText = null; audioDataUrl = null; }">
                @lang.Label
            </button>
        }
    </div>

    @* 수정됨: 결과 박스 안에 Play 버튼을 통합 — 결과 텍스트 옆에 작은 아이콘 버튼으로 배치 *@
    <div class="tr-result-box @(translatedText is not null ? "has-result" : "")">
        @if (translatedText is not null)
        {
            <div class="tr-result-header">
                <p class="tr-result-text">@translatedText</p>
                <button class="tr-play-btn" @onclick="Speak" disabled="@isSpeaking" title="Play">
                    @if (isSpeaking)
                    {
                        <span class="tr-play-spinner"></span>
                    }
                    else
                    {
                        <span>▶</span>
                    }
                </button>
            </div>
            @if (audioDataUrl is not null)
            {
                <audio class="tr-audio" controls autoplay src="@audioDataUrl"></audio>
            }
        }
        else
        {
            <p class="tr-result-placeholder">Translation will appear here.</p>
        }
    </div>

    @if (errorMessage is not null)
    {
        <p class="tr-error">⚠ @errorMessage</p>
    }

    <div class="tr-actions">

        <button class="tr-btn-primary" @onclick="TranslateText"
                disabled="@(isTranslating || string.IsNullOrWhiteSpace(inputText))">
            @if (isTranslating)
            {
                <span class="tr-spinner"></span>
                <span>Translating…</span>
            }
            else
            {
                <span>Translate</span>
            }
        </button>

        @if (translatedText is not null)
        {
            <button class="tr-btn-tts" @onclick="SendToTts">Send to TTS →</button>
            <button class="tr-btn-icon" @onclick="Copy" title="Copy translation">⎘</button>
        }

        @if (!string.IsNullOrWhiteSpace(inputText) || translatedText is not null)
        {
            <button class="tr-btn-clear" @onclick="Clear">Clear</button>
        }

    </div>

</div>

@code {
    private string sourceLang = "auto";
    private string targetLang = "ko";

    private string inputText = "";
    private string? translatedText;
    private string? audioDataUrl;
    private string? errorMessage;
    private bool isTranslating;
    private bool isSpeaking;

    private async Task TranslateText()
    {
        if (string.IsNullOrWhiteSpace(inputText)) return;

        errorMessage = null;
        translatedText = null;
        audioDataUrl = null;
        isTranslating = true;

        try
        {
            translatedText = await TranslationSvc.TranslateAsync(inputText, sourceLang, targetLang);
        }
        catch (Exception ex)
        {
            errorMessage = $"Translation failed: {ex.Message}";
        }
        finally
        {
            isTranslating = false;
        }
    }

    // 추가됨: 번역 결과를 바로 한 번 재생 (한/독은 tts-1-hd 사용)
    private async Task Speak()
    {
        if (translatedText is null) return;

        errorMessage = null;
        audioDataUrl = null;
        isSpeaking = true;

        try
        {
            var model = targetLang is "ko" or "de" ? "tts-1-hd" : "tts-1";
            var bytes = await TtsService.SynthesizeSpeechAsync(translatedText, model: model);
            audioDataUrl = $"data:audio/mpeg;base64,{Convert.ToBase64String(bytes)}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Speech failed: {ex.Message}";
        }
        finally
        {
            isSpeaking = false;
        }
    }

    // 수정됨: static 변수 대신 URL 쿼리 파라미터로 전달 → Blazor 라우팅에서 안정적으로 동작
    private void SendToTts()
    {
        var encoded = Uri.EscapeDataString(translatedText ?? "");
        Nav.NavigateTo($"/?text={encoded}");
    }

    private async Task Copy()
    {
        if (translatedText is not null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", translatedText);
    }

    private void Clear()
    {
        inputText = "";
        translatedText = null;
        audioDataUrl = null;
        errorMessage = null;
    }
}